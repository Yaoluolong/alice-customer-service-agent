# LLM 配置
OPENAI_API_KEY=your_openai_api_key
OPENAI_BASE_URL=
OPENAI_PRIMARY_MODEL=gpt-4o-mini
OPENAI_AUX_MODEL=gpt-4o-mini

# 置信度门控
AGENT_CONFIDENCE_THRESHOLD=0.7

# 语言策略
DEFAULT_REPLY_LANGUAGE=zh-CN
LANGUAGE_POLICY=auto
SUPPORTED_LANGUAGES=zh-CN,en-US
MAX_CONVERSATION_MESSAGES=12
LLM_TIMEOUT_MS=45000

# 数据库配置（按需选择 DATABASE_URL 或分项配置）
DATABASE_URL=postgresql://user:password@localhost:5432/alice
DB_HOST=localhost
DB_PORT=5432
DB_NAME=alice
DB_USER=postgres
DB_PASSWORD=postgres
DB_SSL=false

# 服务配置
PORT=3000
