  "description": "多模态AI客服Agent系统 - 基于LangGraph.js",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "test": "ts-node src/tests/run.ts",
    "start:server": "node dist/server.js",
    "dev:server": "ts-node src/server.ts",
    "test:e2e": "vitest run --config tests/e2e/vitest.config.ts"
