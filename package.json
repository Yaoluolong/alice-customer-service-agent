    "agent",
    "langgraph",
    "multimodal",
    "customer-service"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@langchain/core": "^0.3.0",
    "@langchain/langgraph": "^0.2.0",
    "@langchain/openai": "^0.3.0",
    "@opencommerce/shared-types": "*",
    "axios": "^1.6.0",
    "bullmq": "^5.71.0",
    "cockatiel": "^3.2.1",
    "dotenv": "^17.3.1",
    "ioredis": "^5.10.1",
    "pino": "^10.3.1",
    "prom-client": "^15.1.3",
    "uuid": "^11.1.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "nock": "^14.0.11",
    "ts-node": "^10.9.0",
    "typescript": "^5.3.0",
    "vitest": "^4.1.0"
